# PostgreSQL connection used by load_csv_to_postgres.py and listings_retrieval.py.
# Do not commit real passwords; copy to .env locally if you use a dotenv loader.

DATABASE_URL=postgresql://YOUR_USER@localhost:5432/car_assistant

# Optional: table name created by the loader (default matches load_csv_to_postgres.py).
# LISTINGS_TABLE=autoscout_de_parsed

# Optional: loosen strict match (defaults shown).
# LISTINGS_YEAR_TOLERANCE=2
# LISTINGS_KM_TOLERANCE=20000

# Optional: Ollama JSON router for "quick cards" vs "deep" after listings (defaults to EXTRACTOR_LLM_MODEL).
# RESULTS_ROUTER_LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://127.0.0.1:11434
